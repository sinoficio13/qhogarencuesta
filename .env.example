# Local dev (docker postgres)
DATABASE_URL=postgres://qhogar:qhogar@localhost:5432/qhogar

# Test DB (docker postgres — separate DB to avoid polluting dev data)
TEST_DATABASE_URL=postgres://qhogar:qhogar@localhost:5432/qhogar_test

# Admin auth (set a strong secret in production)
ADMIN_PASSWORD=changeme
ADMIN_SESSION_SECRET=change-me-to-a-random-32-byte-string-in-production

# Production (Neon — set in Vercel env; overrides DATABASE_URL)
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
